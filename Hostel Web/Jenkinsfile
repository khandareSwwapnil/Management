pipeline {
agent any

```
tools {
    jdk 'JDK17'
    maven 'MAVEN3'
    nodejs 'Node18'
}

environment {
    GIT_CREDENTIALS = 'github-token'   
}

stages {

    stage('Checkout Code') {
        steps {
            git branch: 'main',
                url: 'https://github.com/khandareSwwapnil/Hostel-Management-System-.git',
                credentialsId: "${GIT_CREDENTIALS}"
        }
    }

    stage('Backend Build & Test') {
        steps {
            sh 'mvn clean test package'
        }
    }

    stage('Frontend Build') {
        steps {
            dir('Hostel-frontend/hms-frontend') {
                sh 'npm install'
                sh 'npm run build'
            }
        }
    }

    
    stage('Archive Artifacts') {
        steps {
            archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
        }
    }
}

post {
    success {
        echo "✅ BUILD SUCCESS"
    }
    failure {
        echo "❌ BUILD FAILED"
    }
    always {
        cleanWs()
    }
}
```

}
