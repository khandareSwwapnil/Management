pipeline {
    agent any

    tools {
        nodejs 'NodeJS'   // 👈 configure in Jenkins (important)
    }

    stages {

        stage('Checkout Code') {
            steps {
                git credentialsId: 'github-token',
                    url: 'https://github.com/khandareSwwapnil/Management.git',
                    branch: 'main'
            }
        }
        
        stage('Check Java') {
            steps {
                bat 'java -version'
                bat 'echo %JAVA_HOME%'
            }
        }

        // ✅ FRONTEND STAGE
        stage('Frontend Install Dependencies') {
            steps {
                dir('frontend') {   // ⚠️ change if folder name is different
                    bat 'npm install'
                }
            }
        }

        stage('Frontend Test') {
            steps {
                dir('frontend') {
                    bat 'npm test -- --watchAll=false'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    bat 'npm run build'
                }
            }
        }

        // ✅ BACKEND STAGE
        stage('Build Backend') {
            steps {
                dir('Hostel Web') {
                    bat 'mvnw.cmd clean package'
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                dir('Hostel Web') {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Run Application (Local Deploy)') {
            steps {
                dir('Hostel Web') {
                    bat 'start java -jar target/*.jar'
                }
            }
        }
    }

    post {
        success {
            echo '✅ BUILD SUCCESS'
        }
        failure {
            echo '❌ BUILD FAILED'
        }
    }
}